{
  "version": 3,
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/lib/cth_cmake/toolchain.cmake"
      }
    },
    {
      "name": "add_tests",
      "hidden": true,
      "cacheVariables": {
        "LBS_ENABLE_TESTS": true
      }
    },
    {
      "name": "debug-base",
      "hidden": true,
      "inherits": [ "base", "add_tests" ],
      "cacheVariables": {
        "cth_ROOT": "${sourceDir}/../cth/out/install/msvc_debug",
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "release-base",
      "hidden": true,
      "inherits": [ "base", "add_tests" ],
      "cacheVariables": {
        "cth_ROOT": "${sourceDir}/../cth/out/install/msvc_release",
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "windows-base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/out/build/${presetName}",
      "installDir": "${sourceDir}/out/install/${presetName}"
    },
    {
      "name": "msvc-base",
      "hidden": true,
      "inherits": "windows-base",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "cl",
        "CMAKE_CXX_COMPILER": "cl"
      }
    },
    {
      "name": "clang-base",
      "hidden": true,
      "inherits": "windows-base",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "clang-cl",
        "CMAKE_CXX_COMPILER": "clang-cl"
      }
    },
    {
      "name": "msvc_debug",
      "inherits": [
        "msvc-base",
        "debug-base"
      ]
    },
    {
      "name": "msvc_release",
      "inherits": [
        "msvc-base",
        "release-base"
      ]
    },
    {
      "name": "clang_debug",
      "inherits": [
        "clang-base",
        "debug-base"
      ]
    },
    {
      "name": "clang_release",
      "inherits": [
        "clang-base",
        "release-base"
      ]
    }
  ]
}